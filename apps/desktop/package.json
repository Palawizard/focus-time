    "@tanstack/react-query": "^5.85.5",
    "@tauri-apps/api": "^2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.8"
