{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Time",
  "version": "0.1.0",
  "identifier": "com.palawizard.focustime",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Time",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "publisher": "Palawizard",
    "homepage": "https://github.com/Palawizard/focus-time",
    "copyright": "Copyright (c) 2026 Palawizard",
    "license": "MIT",
    "category": "Productivity",
    "shortDescription": "A local-first focus timer with tracking, recovery and desktop controls.",
    "longDescription": "Focus Time helps you run Pomodoro sessions, review history, track app activity, recover from mistakes with local backups and ship a polished desktop experience from a single local workspace.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": {
        "cmd": "bash",
        "args": ["../../../scripts/sign-desktop.sh", "%1"]
      }
    }
  }
}
